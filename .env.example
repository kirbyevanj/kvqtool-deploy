# KVQTool-Web Environment Configuration

# General
KVQ_ENV=development
LOG_LEVEL=debug

# PostgreSQL (app data)
POSTGRES_DB=kvqtool
POSTGRES_USER=kvq
POSTGRES_PASSWORD=kvqdev
POSTGRES_PORT=5432

# Temporal
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8233

# MinIO (S3-compatible)
S3_ACCESS_KEY=kvqminio
S3_SECRET_KEY=kvqminiodev
S3_BUCKET=kvq-bucket
S3_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API Server
API_PORT=8080

# ML Inference
GRPC_PORT=50051

# Frontend
FRONTEND_PORT=80
