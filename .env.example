# KVQTool-Web Environment Configuration
# Copy to .env and modify as needed

# General
KVQ_ENV=development
LOG_LEVEL=debug

# PostgreSQL
POSTGRES_DB=kvqtool
POSTGRES_USER=kvq
POSTGRES_PASSWORD=kvqdev
POSTGRES_PORT=5432

# Valkey (Redis-compatible)
VALKEY_PORT=6379

# MinIO (S3-compatible)
S3_ACCESS_KEY=kvqminio
S3_SECRET_KEY=kvqminiodev
S3_BUCKET=kvq-bucket
S3_REGION=us-east-1
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API Server
API_PORT=8080

# ML Inference
GRPC_PORT=50051

# Frontend
FRONTEND_PORT=80
